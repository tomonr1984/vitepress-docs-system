    "url": "https://github.com/tomonr1984/vitepress-docs-system/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomonr1984/vitepress-docs-system.git"
  },
  "license": "MIT",
  "author": {
    "name": "tomonr1984",
