  "type": "module",
  "description": "A comprehensive documentation management system for custom tools with VitePress, featuring multi-language support and standardized templates",
  "keywords": [
    "documentation",
    "vitepress",
    "tools",
    "multi-language",
    "templates",
    "claude-code",
